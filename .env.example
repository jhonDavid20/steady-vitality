# Database Configuration
# For local development use individual vars:
DB_HOST=localhost
DB_PORT=5432
DB_NAME=steady_vitality
DB_USERNAME=steadyuser
DB_PASSWORD=your_db_password

# For cloud platforms (Render, Railway, etc.) use a single connection string.
# When DATABASE_URL is set, all DB_* vars above are ignored.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# JWT Configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRE=24h
JWT_REFRESH_EXPIRE=7d

# Security Configuration
BCRYPT_ROUNDS=12

# Default Admin Account
DEFAULT_ADMIN_EMAIL=admin@yourdomain.com
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=your_admin_password

# Node environment
NODE_ENV=development
PORT=3001